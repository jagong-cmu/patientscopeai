# Copy to `.env` and fill in secrets. Never commit `.env`.

# PostgreSQL (matches docker-compose defaults unless you override)
# SQLAlchemy: use psycopg v3 (pip install "psycopg[binary]") or psycopg2 (pip install psycopg2-binary)
# Docker maps Postgres to host port 5433 (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://mimic:mimic@127.0.0.1:5433/mimiciv
# Used by backend/services/mimic.py if you prefer discrete vars over DATABASE_URL
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5433
# If your Jupyter kernel is conda-only without psycopg, use instead:
# DATABASE_URL=postgresql+psycopg2://mimic:mimic@127.0.0.1:5433/mimiciv

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional: override model for scripts/notebooks
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Demo census: which stay_id gets full NEWS from vitals on GET /api/stays (others may use deterministic stubs)
# DEMO_STAY_ID=31269608

# Max ICU stays (los ≥ 1) scanned from MIMIC for roster, ward summary, and alerts (MIMIC-IV demo has ~100)
# ICU_STAY_SCAN_LIMIT=100

# Ward dashboard: total staffed ICU beds (display census/beds); optional pending admissions count for throughput UI
# WARD_BED_CAPACITY=100
# WARD_PENDING_ADMISSIONS=0

# MongoDB Atlas connection string (free tier cluster). Required for POST /api/watchlist and POST /api/discharge-events persistence.
# Prefer the "Drivers" URI from Atlas (mongodb+srv://user:password@cluster...). Ensure Network Access allows your IP (or 0.0.0.0/0 for dev).
# If you see TLS/SSL handshake errors, restart the API after pulling updates (the backend pins certifi’s CA bundle for TLS).
MONGODB_URI=

# Vultr: account/API tokens are usually set in deployment tooling, not always in-app
# VULTR_API_KEY=

# Training only (models/train.py): set to 1 to refit with SMOTE after grid search when minority class is large enough
# TRAIN_USE_SMOTE=

# Skip GridSearchCV on large cohorts (hours → minutes). Final RF uses default pipeline hyperparameters.
# TRAIN_SKIP_GRID=1

# Train from a Parquet or CSV export instead of Postgres (e.g. BigQuery “Save results”). Same columns as mimicscope.training_dataset_v1.
# TRAINING_PARQUET=/absolute/path/to/training_export.csv
