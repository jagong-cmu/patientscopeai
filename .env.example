# Copy to `.env` and fill in secrets. Never commit `.env`.

# PostgreSQL (matches docker-compose defaults unless you override)
# SQLAlchemy: use psycopg v3 (pip install "psycopg[binary]") or psycopg2 (pip install psycopg2-binary)
# Docker maps Postgres to host port 5433 (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://mimic:mimic@127.0.0.1:5433/mimiciv
# Used by backend/services/mimic.py if you prefer discrete vars over DATABASE_URL
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5433
# If your Jupyter kernel is conda-only without psycopg, use instead:
# DATABASE_URL=postgresql+psycopg2://mimic:mimic@127.0.0.1:5433/mimiciv

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional: override model for scripts/notebooks
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Demo census: which stay_id gets computed readiness on GET /api/stays (others use stub flags)
# DEMO_STAY_ID=31269608

# MongoDB Atlas connection string (free tier cluster)
MONGODB_URI=

# Vultr: account/API tokens are usually set in deployment tooling, not always in-app
# VULTR_API_KEY=
