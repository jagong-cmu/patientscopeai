# Leave empty for local dev: Vite proxies /api → http://127.0.0.1:8000 (see vite.config.ts).
# Production (e.g. Vercel): set to your FastAPI public URL (no trailing slash), then redeploy so Vite can bake it in:
#   VITE_API_BASE=https://your-api.example.com
VITE_API_BASE=

# Optional: highlight this stay_id on the census (must match backend DEMO_STAY_ID if set)
# VITE_DEMO_STAY_ID=31269608

# Ward occupancy uses backend WARD_BED_CAPACITY (no Vite override).
